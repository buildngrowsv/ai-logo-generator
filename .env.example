# =============================================================================
# SaaS Clone Template — Environment Variables
# =============================================================================
# Copy this to .env.local and fill in your values.
# NEVER commit .env.local to git — it contains secrets.
# =============================================================================

# --- NextAuth (Authentication) ---
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:4837

# --- Google OAuth ---
# Create at: https://console.cloud.google.com/apis/credentials
# Set redirect URI to: http://localhost:4837/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- Stripe (Payments) ---
# Get keys at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
# Webhook secret from: stripe listen --forward-to localhost:4837/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# --- Stripe Price IDs ---
# Create products/prices in Stripe Dashboard or via API
# These are the recurring subscription price IDs for Basic and Pro tiers
STRIPE_PRICE_BASIC=price_basic_monthly_id
STRIPE_PRICE_PRO=price_pro_monthly_id

# --- fal.ai (AI Model Inference) ---
# Get key at: https://fal.ai/dashboard/keys
FAL_KEY=your-fal-ai-key

# --- Database ---
# PostgreSQL connection string (Neon, Supabase, or local)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Upstash Redis (T018: Pro subscription token lifecycle) ---
# Required for Pro subscription bypass of IP rate limiting.
# Get these from: https://console.upstash.com → Create Database → REST API
# Without these, Pro token gating is DISABLED (fail-closed: free tier only).
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-rest-token

# --- Better Auth (if using Better Auth instead of NextAuth) ---
BETTER_AUTH_SECRET=your-better-auth-secret-here
BETTER_AUTH_URL=http://localhost:4837

# --- Cloudflare R2 (Image Storage) ---
# Get from: https://dash.cloudflare.com → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-bucket-name
R2_PUBLIC_URL=https://your-bucket.r2.dev

# --- Stripe Price IDs (Subscription + Credit Packs) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
NEXT_PUBLIC_STRIPE_PRICE_BASIC_MONTHLY=price_basic_monthly_id
NEXT_PUBLIC_STRIPE_PRICE_STANDARD_MONTHLY=price_standard_monthly_id
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly_id
NEXT_PUBLIC_STRIPE_PRICE_STARTER_PACK=price_starter_pack_id
NEXT_PUBLIC_STRIPE_PRICE_GROWTH_PACK=price_growth_pack_id
NEXT_PUBLIC_STRIPE_PRICE_PROFESSIONAL_PACK=price_professional_pack_id

# --- App URL ---
NEXT_PUBLIC_APP_URL=http://localhost:4837

# === Google Analytics 4 [OPTIONAL] ===
# Get from: https://analytics.google.com → Admin → Data Streams → Measurement ID
# Format: G-XXXXXXXXXX — set in Vercel env vars to activate tracking.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# After production deploy: npm run verify:ga-gtag-prod  (or VERIFY_GA4_URL=... for alternate host)
